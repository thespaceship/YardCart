# Copy to .env and fill in. Local dev + tests need Postgres — use an isolated Neon
# branch of production (console → Branches → Create Branch, e.g. "dev"), NEVER prod.
#
# These two are the SAME database reached two ways, and the hosts must differ:
#   DATABASE_URL — pooled endpoint (host contains `-pooler`). Used by the running app.
#   DIRECT_URL   — direct endpoint (same host WITHOUT `-pooler`). Used by prisma migrate.
# Editing `-pooler` out of DATABASE_URL instead of adding DIRECT_URL drops connection
# pooling in production and only shows up under load. See docs/DEPLOY.md.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
# Optional: separate database for `npm test` (defaults to DATABASE_URL)
# TEST_DATABASE_URL=""
SESSION_SECRET="generate with: openssl rand -hex 32"
APP_URL="http://localhost:3000"
# Optional integrations (leave empty for test mode)
RESEND_API_KEY=""
EMAIL_FROM=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
SENTRY_DSN=""
PLAUSIBLE_DOMAIN=""
# Optional: get an email at this address whenever a new yard signs up
OWNER_EMAIL=""
# Product photo storage — Cloudflare R2 (S3-compatible). Leave empty to disable image uploads.
# ACCOUNT_ID is the subdomain of your bucket's S3 API endpoint. Create an Account API token
# (Object Read & Write, scoped to the bucket) for the key/secret. PUBLIC_BASE_URL is the
# bucket's public URL — an r2.dev development URL, or a custom domain like https://img.yourdomain.com
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="yardcart-product-images"
R2_PUBLIC_BASE_URL=""
