# Copy to .env and fill in. Local dev + tests need Postgres — use an isolated Neon
# branch of production (console → Branches → Create Branch, e.g. "dev"), NEVER prod.
DATABASE_URL="postgresql://user:password@ep-xxx-dev.neon.tech/neondb?sslmode=require"
# Optional: separate database for `npm test` (defaults to DATABASE_URL)
# TEST_DATABASE_URL=""
SESSION_SECRET="generate with: openssl rand -hex 32"
APP_URL="http://localhost:3000"
# Optional integrations (leave empty for test mode)
RESEND_API_KEY=""
EMAIL_FROM=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
SENTRY_DSN=""
PLAUSIBLE_DOMAIN=""
# Optional: get an email at this address whenever a new yard signs up
OWNER_EMAIL=""
