generator client {
  provider = "prisma-client-js"
}

// `url` is Neon's pooled endpoint (host contains `-pooler`) and is what the running app uses.
// `directUrl` is the same database over a direct connection, used only by migrate/introspect/studio:
// `migrate dev` needs to create a shadow database, which it cannot do through the pooler. Getting
// these two crossed is silent — see docs/DEPLOY.md.
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("OWNER") // OWNER | STAFF
  yardId       String?  // currently *active* yard in the dashboard
  yard         Yard?    @relation(fields: [yardId], references: [id], onDelete: SetNull)
  memberships  YardMember[] // yards this user owns (Multi plan → up to 5)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Owner → yard(s) membership. Keeps User.yardId as the single "active" yard while allowing a
// Multi-plan owner to own several yards; the yard-switcher and location cap read from here.
model YardMember {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  yardId    String
  yard      Yard     @relation(fields: [yardId], references: [id], onDelete: Cascade)
  role      String   @default("OWNER") // OWNER (staff still attach via User.yardId)
  createdAt DateTime @default(now())

  @@unique([userId, yardId])
  @@index([userId])
}

model Yard {
  id                 String    @id @default(cuid())
  name               String
  slug               String    @unique
  phone              String    @default("")
  email              String    @default("")
  addressLine        String    @default("")
  city               String    @default("")
  state              String    @default("")
  zip                String    @default("")
  aboutText          String    @default("")
  timezone           String    @default("America/New_York") // IANA zone for cutoffs & day math
  // ordering settings
  minLeadDays        Int       @default(1) // earliest delivery = today + minLeadDays
  maxAdvanceDays     Int       @default(30)
  orderCutoffHour    Int       @default(15) // local hour after which "tomorrow" is unavailable
  acceptOnlineOrders Boolean   @default(true)
  paymentOnDelivery  Boolean   @default(true) // accept pay-on-delivery
  deliveryDays       Int[]     @default([0, 1, 2, 3, 4, 5, 6]) // days open for delivery, 0=Sun..6=Sat
  // billing
  plan               String    @default("TRIAL") // TRIAL | STARTER | PRO | MULTI
  planStatus         String    @default("TRIALING") // TRIALING | ACTIVE | PAST_DUE | CANCELED
  trialEndsAt        DateTime?
  stripeCustomerId   String?
  stripeSubscriptionId    String?  // active Stripe subscription (null once canceled)
  stripeCancelAtPeriodEnd Boolean  @default(false) // sub set to cancel at period end
  onboardedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  users            User[]
  members          YardMember[]
  products         Product[]
  categories       Category[]
  zones            Zone[]
  trucks           Truck[]
  orders           Order[]
  invoices         Invoice[]
  deliveryMethods  DeliveryMethod[]
  deliveryAddOns   DeliveryAddOn[]
}

// Storefront product categories, owned by the yard. `slug` is what Product.category stores, so it
// is immutable once created (renaming would orphan products); `label` is the display name and is
// freely editable. Every yard starts with the six built-ins and can add its own (sand, construction
// material, …). sortOrder drives the section order customers see on the storefront.
model Category {
  id        String   @id @default(cuid())
  yardId    String
  yard      Yard     @relation(fields: [yardId], references: [id], onDelete: Cascade)
  slug      String
  label     String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([yardId, slug])
  @@index([yardId])
}

model Product {
  id          String      @id @default(cuid())
  yardId      String
  yard        Yard        @relation(fields: [yardId], references: [id], onDelete: Cascade)
  name        String
  category    String      @default("mulch") // Category.slug for this yard (see model Category)
  description String      @default("")
  unit        String      @default("cubic_yard") // cubic_yard | half_yard | bag | cord | face_cord | ton
  priceCents  Int
  minQty      Float       @default(1)
  maxQty      Float       @default(30)
  qtyStep     Float       @default(0.5)
  active      Boolean     @default(true)
  sortOrder   Int         @default(0)
  // How much of a truck one unit consumes, for delivery-method limits (see lib/load.ts).
  // yardsPerUnit null = derive from `unit` (a cubic yard is 1, a half yard 0.5, else 0).
  // 0 on weight/pallets means "don't count this product toward that limit".
  yardsPerUnit     Float?
  weightLbsPerUnit Float   @default(0)
  palletsPerUnit   Float   @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
  methods     ProductMethod[]
  addOns      ProductAddOn[]
}

model Zone {
  id               String   @id @default(cuid())
  yardId           String
  yard             Yard     @relation(fields: [yardId], references: [id], onDelete: Cascade)
  name             String
  zipCodes         String   // JSON array of ZIP strings
  // Fallback fee, used when no DeliveryRate row exists for (zone, method). Also the tiebreak
  // when a ZIP matches several zones — keep it set even once the rate grid is filled in.
  deliveryFeeCents Int
  minOrderCents    Int      @default(0)
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  orders           Order[]
  rates            DeliveryRate[]
}

/**
 * A way the yard delivers — "Medium dump truck", "Flatbed w/ forklift" — not a physical truck.
 * Three identical dump trucks are one method; the customer sees one option.
 *
 * Limits are per delivery. 0 means "don't enforce this dimension", which is how a yard says
 * "cap gravel by weight but let mulch go by volume". A cart's trip count is the ceiling of the
 * hardest-binding dimension — see lib/load.ts.
 */
model DeliveryMethod {
  id                 String   @id @default(cuid())
  yardId             String
  yard               Yard     @relation(fields: [yardId], references: [id], onDelete: Cascade)
  name               String
  description        String   @default("")
  maxYards           Float    @default(0)
  maxWeightLbs       Float    @default(0)
  maxPallets         Float    @default(0)
  allowMultipleTrips Boolean  @default(true)
  quoteOnly          Boolean  @default(false) // too big to price online — "call for a quote"
  sortOrder          Int      @default(0)
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  rates    DeliveryRate[]
  products ProductMethod[]
  trucks   Truck[]
  orders   Order[]

  @@index([yardId])
}

/** One cell of the zone × method fee grid. Sparse: a missing row falls back to Zone.deliveryFeeCents. */
model DeliveryRate {
  id       String         @id @default(cuid())
  zoneId   String
  zone     Zone           @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  methodId String
  method   DeliveryMethod @relation(fields: [methodId], references: [id], onDelete: Cascade)
  feeCents Int

  @@unique([zoneId, methodId])
  @@index([methodId])
}

/**
 * Equipment or service billed on top of the delivery fee — a forklift to get pallets off the
 * truck, say. Applied automatically when the cart contains a product that requires it.
 */
model DeliveryAddOn {
  id        String   @id @default(cuid())
  yardId    String
  yard      Yard     @relation(fields: [yardId], references: [id], onDelete: Cascade)
  name      String
  feeCents  Int      @default(0)
  perTrip   Boolean  @default(true) // charged per trip, not once per order
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products ProductAddOn[]

  @@index([yardId])
}

/** Products a method may carry. No rows for a product = it can go on any method. */
model ProductMethod {
  productId String
  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  methodId  String
  method    DeliveryMethod @relation(fields: [methodId], references: [id], onDelete: Cascade)

  @@id([productId, methodId])
  @@index([methodId])
}

/** Equipment a product requires in order to be delivered. */
model ProductAddOn {
  productId String
  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  addOnId   String
  addOn     DeliveryAddOn @relation(fields: [addOnId], references: [id], onDelete: Cascade)

  @@id([productId, addOnId])
  @@index([addOnId])
}

model Truck {
  id            String   @id @default(cuid())
  yardId        String
  yard          Yard     @relation(fields: [yardId], references: [id], onDelete: Cascade)
  name          String
  // Dead: superseded by DeliveryMethod.maxYards. No longer written or displayed — a per-truck
  // yardage that affected nothing was actively misleading next to the method's real limits.
  // Left in place because dropping a column needs a migration for no gain; safe to remove later.
  capacityYards Float    @default(10)
  maxTripsPerDay Int     @default(6)
  deliveryMethodId String?
  deliveryMethod   DeliveryMethod? @relation(fields: [deliveryMethodId], references: [id], onDelete: SetNull)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  orders        Order[]
}

model Order {
  id             String      @id @default(cuid())
  yardId         String
  yard           Yard        @relation(fields: [yardId], references: [id], onDelete: Cascade)
  number         Int // per-yard sequential display number
  channel        String      @default("ONLINE") // ONLINE | PHONE
  status         String      @default("NEW") // NEW | SCHEDULED | OUT_FOR_DELIVERY | DELIVERED | CANCELED
  customerName   String
  customerPhone  String
  customerEmail  String      @default("")
  addressLine    String
  city           String      @default("")
  zip            String
  zoneId         String?
  zone           Zone?       @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  placementNotes String      @default("") // customer instructions ("dump on left side of driveway")
  internalNotes  String      @default("")
  materialCents  Int
  deliveryCents  Int
  totalCents     Int
  // Snapshots so history survives a method being renamed or retired, same as OrderItem.nameSnap.
  deliveryMethodId   String?
  deliveryMethod     DeliveryMethod? @relation(fields: [deliveryMethodId], references: [id], onDelete: SetNull)
  deliveryMethodSnap String  @default("")
  tripCount          Int     @default(1)
  deliveryAddOnsSnap String  @default("[]") // JSON [{name, feeCents}] actually charged
  paymentStatus  String      @default("UNPAID") // UNPAID | PAY_ON_DELIVERY | PAID
  paymentMethod  String      @default("") // cash | check | card | online_test
  requestedDate  DateTime? // customer's requested delivery date
  scheduledDate  DateTime? // confirmed dispatch date
  scheduledSlot  String      @default("") // AM | PM | ""
  truckId        String?
  truck          Truck?      @relation(fields: [truckId], references: [id], onDelete: SetNull)
  driverName     String      @default("")
  deliveredAt    DateTime?
  canceledAt     DateTime?
  cancelReason   String      @default("")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  items          OrderItem[]

  @@unique([yardId, number])
  @@index([yardId, status])
  @@index([yardId, scheduledDate])
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String?
  product    Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  nameSnap   String // product name at time of order
  unitSnap   String
  qty        Float
  unitCents  Int
  totalCents Int
}

// Test-mode outbound email mailbox (viewable in app; swap to Resend/SendGrid via env)
model EmailLog {
  id        String   @id @default(cuid())
  yardId    String?
  toEmail   String
  subject   String
  html      String
  kind      String // order_confirmation | new_order_alert | scheduled | delivered | auth | billing
  sentVia   String   @default("TEST_MAILBOX") // TEST_MAILBOX | RESEND
  createdAt DateTime @default(now())

  @@index([yardId, createdAt])
}

// Lightweight first-party analytics
model EventLog {
  id        String   @id @default(cuid())
  yardId    String?
  type      String // storefront_view | order_placed | signup | onboarded | login | checkout_started ...
  meta      String   @default("{}")
  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([yardId, createdAt])
}

// Server error monitoring (first-party; Sentry optional via env)
model ErrorLog {
  id        String   @id @default(cuid())
  where     String
  message   String
  stack     String   @default("")
  createdAt DateTime @default(now())
}

// Billing records (test mode)
model Invoice {
  id          String   @id @default(cuid())
  yardId      String
  yard        Yard     @relation(fields: [yardId], references: [id], onDelete: Cascade)
  amountCents Int
  plan        String
  periodStart DateTime
  periodEnd   DateTime
  status      String   @default("TEST_PAID") // TEST_PAID | PAID | VOID
  provider    String   @default("MOCK") // MOCK | STRIPE_TEST | STRIPE
  externalId  String   @default("")
  createdAt   DateTime @default(now())
}
